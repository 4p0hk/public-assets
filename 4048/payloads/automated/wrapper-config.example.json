{
  "schema_version": 3,
  "debug": false,
  "rule_name": "WF2025.4048 Exfiltration_via_Azure_CLI",
  "jira": {
    "base_url": "https://securityjira.c2mc-cdv.net",
    "issue_key": "ABC-1234",
    "pat": "PASTE_YOUR_PAT_HERE",
    "dry_run": false
  },
  "timing": {
    "lookback_seconds": 1800,
    "cron_minutes": [12, 27, 42, 57],
    "throttle_seconds": 1500,
    "ingest_buffer_seconds": 300
  },
  "stages": [
    {
      "name": "evasion-sdk-iwr-piece-1",
      "script": "manual/01-sdk-iwr-evasion/script.bat",
      "wait_strategy": "fixed_seconds",
      "delay_seconds": 10
    },
    {
      "name": "evasion-azcopy-piece-2",
      "script": "manual/02-azcopy-evasion/script.bat",
      "wait_strategy": "fixed_seconds",
      "delay_seconds": 10
    },
    {
      "name": "trigger-direct-piece-3",
      "script": "manual/03-direct-az-cli-piece-3/script.bat",
      "wait_strategy": "next_clean_cron"
    },
    {
      "name": "trigger-direct-piece-4",
      "script": "manual/04-direct-az-cli-piece-4/script.bat",
      "wait_strategy": "none"
    }
  ],
  "validator": "manual/validator.ps1",
  "cleanup": "manual/cleanup.ps1"
}
